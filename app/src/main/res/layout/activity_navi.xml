<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 摄像头预览层 -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 检测框叠加层 -->
    <View
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 顶部渐变遮罩 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_top"
        android:layout_gravity="top" />

    <!-- 底部渐变遮罩 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/gradient_bottom"
        android:layout_gravity="bottom" />

    <!-- 主内容层 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_dark"
                android:contentDescription="返回"
                android:src="@android:drawable/ic_menu_revert"
                android:scaleX="1.3"
                android:scaleY="1.3"
                app:tint="#FFFFFF" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_status_dot_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="步行导航"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 导航信息卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_navi_panel"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/navi_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="步行导航"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/navi_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="准备出发"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:lineSpacingExtra="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剩余距离"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/navi_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 公里"
                        android:textColor="#4CAF50"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="30dp"
                    android:background="#333333" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剩余时间"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/navi_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18 分钟"
                        android:textColor="#2196F3"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/navi_next"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="下一步：直行"
                android:textSize="16sp"
                android:textColor="#FF9800"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333333"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_exit_navi"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="退出导航"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>