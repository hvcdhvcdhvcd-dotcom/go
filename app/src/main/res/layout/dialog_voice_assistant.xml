<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_voice_dialog">

    <!-- 顶部拖动条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- 波形动画区域 - 占满宽度 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp">

        <!-- 波形动画视图 - 宽度占满，高度80dp -->
        <com.example.myapplication.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="center" />

        <!-- 麦克风图标 - 放在波形上方居中 -->
        <ImageView
            android:id="@+id/micIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_mic_white"
            android:background="@drawable/bg_mic_pulse"
            android:padding="14dp"
            app:tint="#FFFFFF" />

    </FrameLayout>

    <!-- 识别文字显示区 -->
    <TextView
        android:id="@+id/tvRecognizedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请说话..."
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:minHeight="80dp"
        android:background="@drawable/bg_text_area" />

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="说出目的地，如：去武汉大学"
        android:textSize="14sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:padding="16dp" />

    <!-- 底部按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp"
        android:background="@drawable/bg_button_row">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="取消"
            android:textSize="16sp"
            android:backgroundTint="#424242"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="确认导航"
            android:textSize="16sp"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>