<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 相机预览（全屏） -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

    <!-- 顶部渐变遮罩（提升文字可读性） -->
    <View
        android:id="@+id/topGradient"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/gradient_top"
        android:layout_alignParentTop="true" />

    <!-- 底部渐变遮罩 -->
    <View
        android:id="@+id/bottomGradient"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/gradient_bottom"
        android:layout_alignParentBottom="true" />

    <!-- 返回按钮 -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_circle_dark"
        android:contentDescription="返回"
        android:src="@android:drawable/ic_menu_revert"
        android:scaleX="1.3"
        android:scaleY="1.3"
        app:tint="#FFFFFF" />

    <!-- 右上角状态指示器 -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_status_chip"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/bg_status_dot_green" />

        <TextView
            android:id="@+id/tvObstacleStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="障碍检测中"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 当前语音播报状态条 -->
    <LinearLayout
        android:id="@+id/speakingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/statusContainer"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_speaking_chip"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:visibility="gone"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvSpeakingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在播报..."
            android:textColor="#4CAF50"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 底部导航信息面板 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_navi_panel"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 目的地行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="目的地"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDestination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="未设置"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#444444"
                android:layout_marginHorizontal="12dp" />

            <TextView
                android:id="@+id/tvNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="等待指令"
                android:textColor="#FF9800"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="12dp" />

        <!-- 导航主指令 -->
        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请说出目的地"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:lineSpacingExtra="4dp" />

        <!-- 距离和时间行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="剩余距离"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#4CAF50"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="30dp"
                android:background="#333333" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="剩余时间"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#2196F3"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 语音指令按钮 -->
        <Button
            android:id="@+id/btnVoiceCommand"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="语音指令"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

    </LinearLayout>

</RelativeLayout>